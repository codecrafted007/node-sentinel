# vhs script for the node-sentinel demo GIF.
#   vhs docs/demo/demo.tape   →   docs/demo/node-sentinel-demo.gif
# Content is a redacted, representative walkthrough (see demo.sh) — no cluster.
Output docs/demo/node-sentinel-demo.gif

Set Shell bash
Set FontSize 15
Set Width 1080
Set Height 700
Set Theme "Dracula"
Set Padding 16
Set Framerate 24

Type "bash docs/demo/demo.sh"
Enter
Sleep 22s
