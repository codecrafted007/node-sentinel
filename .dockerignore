# The build compiles from source inside the image (see Dockerfile), so the
# context needs the Go/BPF sources + go.mod/go.sum + the committed vmlinux.h.
# Exclude everything that isn't an input to the build.
.git
.github
bin
docs
deploy
*.md

# bpf2go output is regenerated in the builder; never ship a dev's stale copy.
*.o
internal/ebpf/sched_bpfel.go
internal/ebpf/sched_bpfeb.go
internal/ebpf/blkio_bpfel.go
internal/ebpf/blkio_bpfeb.go
internal/ebpf/net_bpfel.go
internal/ebpf/net_bpfeb.go
